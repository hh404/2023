import json
from collections import defaultdict

def infer_type(value):
    if value is None:
        return "null"
    elif isinstance(value, bool):
        return "bool"
    elif isinstance(value, int):
        return "int"
    elif isinstance(value, float):
        return "float"
    elif isinstance(value, str):
        return "string"
    elif isinstance(value, list):
        return "array"
    elif isinstance(value, dict):
        return "object"
    return "unknown"

def merge_types(existing, new):
    if existing == new:
        return existing
    return f"{existing}|{new}"

def analyze_object(obj, schema):
    for k, v in obj.items():
        t = infer_type(v)

        if k not in schema:
            schema[k] = {
                "type": t,
                "nullable": v is None
            }
        else:
            schema[k]["type"] = merge_types(schema[k]["type"], t)
            if v is None:
                schema[k]["nullable"] = True

def analyze_json(data):
    schema = {}

    if isinstance(data, list):
        for item in data:
            if isinstance(item, dict):
                analyze_object(item, schema)
    elif isinstance(data, dict):
        analyze_object(data, schema)

    return schema

def print_schema(schema):
    print("Fields:")
    for k, v in schema.items():
        nullable = "nullable" if v["nullable"] else "non-null"
        print(f"- {k}: {v['type']} ({nullable})")

# === 使用方式 ===
if __name__ == "__main__":
    with open("input.json", "r", encoding="utf-8") as f:
        data = json.load(f)

    schema = analyze_json(data)
    print_schema(schema)
